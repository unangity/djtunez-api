# GCP
project_id = "djtunez"
region     = "europe-west1"

# Used only on first apply to bootstrap the Cloud Run service.
# After the first CI deploy (push to main), remove this line.
image = "gcr.io/cloudrun/hello:latest"

# GitHub
# Generate at https://github.com/settings/tokens — needs 'repo' scope
github_token = "ghp_..."
github_repo  = "owner/djtunez-api"

# Stripe
stripe_secret_key     = "sk_live_..."
stripe_webhook_secret = "whsec_..."

# Spotify
spotify_client_id     = ""
spotify_client_secret = ""

# App config
# platform_fee_percent  = "10"
custom_domain          = "api.reqrave.com"
prod_frontend_hostname = "reqrave.com"

# Email (contact form)
smtp_host         = ""
smtp_port         = "587"
smtp_user         = "noreply@reqrave.com"
smtp_password     = ""
contact_recipient = ""